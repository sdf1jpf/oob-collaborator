# Domain configuration
DOMAIN=yourdomain.com
PUBLIC_IP=0.0.0.0
NS_HOST=ns1

# Database
DATABASE_URL=postgres://collaborator:collaborator@postgres:5432/collaborator?sslmode=disable

# Admin authentication
ADMIN_PASSWORD=changeme
JWT_SECRET=change-this-to-a-long-random-string

# Burp polling shared token
POLL_TOKEN=changeme-poll-token

# ACME / Let's Encrypt
ACME_EMAIL=admin@yourdomain.com
ACME_STAGING=false

# Server
HTTP_PORT=80
HTTPS_PORT=443
DNS_PORT=53
SMTP_PORT=25
SMTPS_PORT=587

# Logging unknown tokens (no matching payload)
LOG_UNKNOWN_TOKENS=true

# Payload subdomain token length (4-32, default 6). Example: a3k9xm.yourdomain.com
PAYLOAD_TOKEN_LENGTH=6
