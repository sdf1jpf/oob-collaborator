# Domain configuration
DOMAIN=yourdomain.com
PUBLIC_IP=0.0.0.0
NS_HOST=ns1

# Database — generate a strong password: openssl rand -base64 32
POSTGRES_USER=collaborator
POSTGRES_PASSWORD=
POSTGRES_DB=collaborator
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Use sslmode=require when Postgres enforces TLS (recommended in production)
POSTGRES_SSLMODE=disable
DATABASE_URL=postgres://collaborator:CHANGE_ME@postgres:5432/collaborator?sslmode=disable

# Admin authentication — generate secrets: openssl rand -base64 32
ADMIN_PASSWORD=
JWT_SECRET=

# Burp polling shared token — generate: openssl rand -base64 32
POLL_TOKEN=

# ACME / Let's Encrypt
ACME_EMAIL=admin@yourdomain.com
ACME_STAGING=false

# Server
HTTP_PORT=80
HTTPS_PORT=443
DNS_PORT=53
SMTP_PORT=25
SMTPS_PORT=587

# Logging unknown tokens (no matching payload); default false
LOG_UNKNOWN_TOKENS=false

# Payload subdomain token length (4-32, default 6). Example: a3k9xm.yourdomain.com
PAYLOAD_TOKEN_LENGTH=6
